### Call Type - Donut plot
```{r}
table(Forest_Data_clean$Call)
#.  CAV    CST     DS DS_mod  GROWL     US US_mod    VEX 
#   313    310    419    106    215    529    242    191 

#Need to make a new dataframe with separate columns for categories and counts
Call_Counts<- data.frame(
  Call = c("Constant", "Up-sweep", "Modified Up-sweep", "Down-sweep", "Modified Down-sweep", "Growl", "Concave", "Convex"),
  Counts = c(310, 529, 242, 419, 106, 215, 313, 191)
)

Call_Counts<-Call_Counts %>% 
  dplyr::mutate(Call = factor(Call, levels = c("Constant", "Up-sweep", "Modified Up-sweep", "Down-sweep", "Modified Down-sweep", "Growl", "Concave", "Convex")))

# Compute percentages
Call_Counts$fraction = Call_Counts$Counts / sum(Call_Counts$Counts)

# Compute the cumulative percentages (top of each rectangle)
Call_Counts$ymax = cumsum(Call_Counts$fraction)

# Compute the bottom of each rectangle
Call_Counts$ymin = c(0, head(Call_Counts$ymax, n=-1))

#Compute label positions
Call_Counts$labelPosition <- (Call_Counts$ymax + Call_Counts$ymin) /2

BH_Call_Donut<- ggplot(Call_Counts,
                       aes(ymax=ymax,
                           ymin=ymin,
                           xmax=4,
                           xmin=3,
                           fill=Call)) +
  geom_rect() +
  coord_polar(theta="y") + # Try to remove that to understand how the chart is built initially
  xlim(c(2,
         4)) + # Try to remove that to see how to make a pie chart
  scale_fill_viridis_d(option = "viridis", direction = -1) +
  geom_label(x = 3.5,
              aes(y = labelPosition,
                  label = Counts),
              size = 8,
              color = "white",
              fontface = "bold", 
              fill = "black") +
  guides(fill = guide_legend(title = "Call Category",
