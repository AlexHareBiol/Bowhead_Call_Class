##Load Data
```{r}
#Load raw data
BH_Call_Data<- read_csv("/Directory/BH_Call_Data_20260217.csv")

#Remove low quality calls and do last-minute cleaning
BH_HQ_Data<-BH_Call_Data %>%
  filter(Quality != "LOW") %>%
  filter(Quality != "NA") %>%
  droplevels() %>%
  mutate(n_harmonics = as.numeric(n_harmonics),
         n_inflections = as.numeric(n_inflections)) %>%
  dplyr::mutate(site = factor(site, levels = c("CB50",
                                               "CB300",
                                               "PP",
                                               "CP",
                                               "FB",
                                               "HI",
                                               "SH",
                                               "UL")))
```





